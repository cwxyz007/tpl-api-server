{
  "compilerOptions": {
    "moduleResolution": "node",
    "noImplicitThis": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "strict": true,
    "target": "es2017",
    "baseUrl": ".",
    "outDir": "dist"
  },
  "include": ["src", "__tests__"],
  "exclude": ["node_modules"]
}
